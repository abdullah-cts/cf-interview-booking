{
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/$1"
    },
    {
      "source": "/delete",
      "destination": "/delete.html"
    },
    {
      "source": "/log",
      "destination": "/log.html"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}